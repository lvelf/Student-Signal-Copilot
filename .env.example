# CriticalAsset credentials — server-side only. NEVER commit the real .env.
CA_CLIENT_ID=your-client-id-here
CA_CLIENT_SECRET=your-client-secret-here
CA_BASE_URL=https://40irving.stg.criticalasset.com
PORT=3000

# Optional — powers the Challenge 02 multi-agent pipeline with real Claude.
# Without it, the pipeline still runs on grounded deterministic stubs.
ANTHROPIC_API_KEY=
# Tiered models: overview uses the expensive model; specialists use a cheap small one.
ANTHROPIC_MODEL_HEAVY=claude-sonnet-4-6
ANTHROPIC_MODEL_LIGHT=claude-haiku-4-5-20251001
